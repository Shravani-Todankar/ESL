                                <span class="small text-secondary" style="color: #6B7280;">World Champions</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Story 4 -->
                <div class="story-card snap-center">
                    <div class="story-image">
                        <img src="assets/slider/Akshit.png" alt="Student working on creative project" />
                    </div>
                    <div class="p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">

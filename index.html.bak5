    <!-- ===== STORIES SECTION ===== -->
    <section class="stories-section" id="stories">
        <!-- Navigation Arrows positioned at right end -->
        <div class="stories-nav-arrows">
            <button class="nav-arrow" id="story-prev">
                <span class="material-icons">chevron_left</span>
            </button>
            <button class="nav-arrow" id="story-next">
                <span class="material-icons">chevron_right</span>
            </button>
        </div>
        <div class="container-fluid">
            <div class="horizontal-scroll-section" id="stories-scroll">
                <!-- Add heading for ESL home page specific formatting -->
                <div class="stories-heading-container" id="stories-heading">
                    <div class="stories-gif gif-left"><img src="assets/recognition.gif" alt="Recognition"></div>
                    <h2>Recognised<br>Innovations</h2>
                    <div class="stories-gif gif-right"><img src="assets/idea.gif" alt="Idea"></div>
                </div>
                <!-- Story 1 -->
                <div class="story-card snap-center">
                    <div class="story-image">
                        <img src="assets/slider/aryan-singh.png"
                            alt="Young student entrepreneur presenting a prototype" />
                    </div>
                    <div class="p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h3 class="h5 fw-bold mb-1" style="font-weight: 600; font-size: 1.2rem !important;">
                                    Aryan Singh</h3>
                                <p class="small mb-0" style="color: #6B21A8; font-weight: 500;">Grade 12,
                                    Rajasthan</p>
                            </div>
                            <span class="story-badge">Social Impact</span>
                        </div>
                        <p class="text-secondary fst-italic mb-4" style="color: #4B5563; font-size: 0.9rem !important;">
                            "Aryan's Mera Sathi Agrotech combines tech of the future with empathy & innovation - his
                            idea earned recognition from Hon'ble PM of India for solving real agricultural challenges."
                        </p>
                        <div class="pt-3 border-top" style="border-top: 1px solid #e5e7eb !important;">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold" style="font-weight: 600;">Agri-Tech</span>
                                <span class="small text-secondary" style="color: #6B7280;">Nationally Recognized</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Story 2 -->
                <div class="story-card snap-center">
                    <div class="story-image">
                        <img src="assets/slider/Atulya.png" alt="Group of students brainstorming with sticky notes" />
                    </div>
                    <div class="p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h3 class="h5 fw-bold mb-1" style="font-weight: 600; font-size: 1.2rem !important;">
                                    Atulya</h3>
                                <p class="small mb-0" style="color: #6B21A8; font-weight: 500;">Grade 10,
                                    Bihar</p>
                            </div>
                            <span class="story-badge">Green Mobility</span>
                        </div>
                        <p class="text-secondary fst-italic mb-4" style="color: #4B5563; font-size: 0.9rem !important;">
                            "Atulya solved daily village commute challenges by developing an E-cycle - an idea that was
                            recognised by the Hon'ble PM of India at the 3rd NEP Anniversary"
                        </p>
                        <div class="pt-3 border-top" style="border-top: 1px solid #e5e7eb !important;">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold" style="font-weight: 600;">Eco-Transport</span>
                                <span class="small text-secondary" style="color: #6B7280;">Nationally Recognized</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Story 3 -->
                <div class="story-card snap-center">
                    <div class="story-image">
                        <img src="assets/slider/Divya.avif" alt="Enthusiastic students receiving an award" />
                    </div>
                    <div class="p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">

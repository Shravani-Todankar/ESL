                            <div class="impact-v2-label-window">
                                <div id="label-roller" class="impact-v2-label-roller">
                                    <div class="impact-v2-label-item">States in India</div>
                                    <div class="impact-v2-label-item">Partner Schools</div>
                                    <div class="impact-v2-label-item">Future Leaders</div>
                                    <div class="impact-v2-label-item">Thinking Coaches</div>

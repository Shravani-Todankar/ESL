                        </div>

                        <!-- Right Side: Dynamic Number & Label -->
                        <div class="impact-v2-right" id="counter-display">

                            <div class="impact-v2-number-window">
                                <div id="number-roller" class="impact-v2-number-roller">
                                    <div class="impact-v2-roller-item">7+</div>
                                    <div class="impact-v2-roller-item">680+</div>
                                    <div class="impact-v2-roller-item">180,000+</div>
                                    <div class="impact-v2-roller-item">145+</div>
                                </div>
